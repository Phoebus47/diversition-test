# Database (optional – app uses mock data if unset)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# When using Docker: docker-compose sets DATABASE_URL for the app; .env is only needed for db:push/db:seed from host.
DATABASE_URL="mysql://root:password@localhost:3306/gallery"

# SonarQube (optional – for npm run sonar)
# Generate token at http://localhost:9001 → My Account → Security → Generate Token
SONAR_TOKEN=your-token-here
